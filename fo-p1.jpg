LAVAL.storageKey = 'laval-config';
LAVAL.getSavedConfig = function () {
  try {
    return JSON.parse(localStorage.getItem(LAVAL.storageKey) || '{}');
  } catch (error) {
    return {};
  }
};

LAVAL.saveConfig = function (config) {
  localStorage.setItem(LAVAL.storageKey, JSON.stringify(config));
};

LAVAL.getByCode = function (collection, code) {
  return (collection || []).find(item => item.code === code);
};

LAVAL.renderAssetImage = function renderAssetImage(src, alt, className = 'media-image') {
  return `<img src="${src}" alt="${alt}" class="${className}" loading="lazy">`;
};

LAVAL.getReferencePreview = function getReferencePreview(config = {}) {
  const profile = LAVAL.getByCode(LAVAL.brand.profiles, config.profileCode);
  const family = LAVAL.getByCode(LAVAL.brand.families, config.familyCode) || LAVAL.brand.families[0];
  return {
    src: profile?.previewImage || family.heroImage,
    alt: profile ? `${profile.name} representative reference image` : `${family.name} representative reference image`,
    label: 'Representative reference image',
    note: 'Selections stay structured and real. The MVP summary uses a representative reference image instead of a fake composited custom render.'
  };
};

LAVAL.renderReferencePreview = function renderReferencePreview(config = {}) {
  const preview = LAVAL.getReferencePreview(config);
  return `
    <div class="reference-frame">
      ${LAVAL.renderAssetImage(preview.src, preview.alt, 'reference-image')}
      <div class="reference-badge">${preview.label}</div>
      <div class="reference-note">${preview.note}</div>
    </div>`;
};

LAVAL.formatSelectionSummary = function formatSelectionSummary(config) {
  const family = LAVAL.getByCode(LAVAL.brand.families, config.familyCode);
  const profile = LAVAL.getByCode(LAVAL.brand.profiles, config.profileCode);
  const leg = LAVAL.getByCode(LAVAL.brand.legs, config.legCode);
  const shelf = LAVAL.getByCode(LAVAL.brand.shelves, config.shelfCode);
  const finish = LAVAL.getByCode(LAVAL.brand.finishes, config.finishCode);
  return {
    family: family?.name || 'Not selected',
    profile: profile?.name || 'Not selected',
    leg: leg?.name || 'Not selected',
    shelf: shelf?.name || 'Not selected',
    finish: finish?.name || 'Not selected'
  };
};
